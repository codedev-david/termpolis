{
  "name": "mv",
  "description": "Move (rename) files",
  "subcommands": [],
  "options": [
    { "name": ["-v", "--verbose"], "description": "Explain what is being done" },
    { "name": ["-i", "--interactive"], "description": "Prompt before overwriting" },
